{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "cargo",
      "command": "build",
      "args": ["--bin=server"],
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "cargo build release",
      "type": "cargo",
      "command": "build",
      "args": ["--bin=server", "--release"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run",
      "type": "cargo",
      "command": "run",
      "args": ["--bin=server"],
      "problemMatcher": ["$rustc"],
      "group": "test"
    }
  ]
}
