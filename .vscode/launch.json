{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug server (CodeLLDB)",
      "cargo": {
        "args": ["build", "--bin=server"],
        "filter": {
          "name": "server",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "type": "cppdbg",
      "request": "launch",
      "name": "Debug server (GDB)",
      "program": "${workspaceFolder}/target/debug/server",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "envFile": "${workspaceFolder}/.env",
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "cargo build",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run server (release)",
      "cargo": {
        "args": ["build", "--bin=server", "--release"],
        "filter": {
          "name": "server",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
